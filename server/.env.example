# HTTP server
FARMEASY_HOST=0.0.0.0
FARMEASY_PORT=8000
FARMEASY_RELOAD=0

# Model bundle paths
# The backend auto-detects ./FarmEasy_Integration_Bundle first, then ./model.
# Set these only when your bundle lives somewhere else.
# FARMEASY_BUNDLE_DIR=./model
# FARMEASY_ENSEMBLE_DIR=./model/ensemble_out_v2
# FARMEASY_GATE_DIR=./model/leaf_gate_out

# Inference defaults
FARMEASY_MODELS=effb3
FARMEASY_TTA=0
FARMEASY_GATE_THRESHOLD=0.5
FARMEASY_CONF_THRESHOLD=0.45
FARMEASY_LOAD_ON_STARTUP=1
FARMEASY_SERIALIZE_INFERENCE=1

# API behavior
FARMEASY_MAX_UPLOAD_MB=10
FARMEASY_MAX_VIDEO_UPLOAD_MB=100
FARMEASY_CORS_ORIGINS=*

# MCP behavior
FARMEASY_MCP_ENABLED=1
FARMEASY_MCP_HOST=127.0.0.1
FARMEASY_MCP_PORT=8001
FARMEASY_ALLOWED_IMAGE_ROOT=.
